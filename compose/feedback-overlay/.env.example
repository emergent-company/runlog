# GitHub App credentials (create at: https://github.com/organizations/<org>/settings/apps)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://feedback.emergent-company.ai/auth/callback

# GitHub App private key (PEM file mounted at /run/secrets/gh-app.pem)
# Generate: openssl genpkey -algorithm RSA -out gh-app.pem -pkeyopt rsa_keygen_bits:4096
GITHUB_APP_PRIVATE_KEY_PATH=./gh-app.pem

# GitHub App installation ID
GITHUB_INSTALLATION_ID=

# JWT signing secret (generate: openssl rand -hex 32)
JWT_SECRET=

# Feedback DB path inside container
DB_PATH=/data/feedback-overlay.db

# Allowed CORS origins (* for development)
ALLOWED_ORIGINS=*
