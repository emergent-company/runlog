package main

import (
	"fmt"
	"strings"

	"github.com/emergent-company/go-daisy/components/layout"
	"github.com/emergent-company/go-daisy/components/table"
	"github.com/emergent-company/go-daisy/components/ui"
	runlog "github.com/emergent-company/runlog"
)

type eventKindDoc struct {
	Kind        string
	Description string
	Usage       string
	IsMeta      bool
}

var eventKinds = []eventKindDoc{
	{Kind: "section", Description: "Logical grouping of child events. Children rendered as expandable sub-table on click.", Usage: "rl.Section()", IsMeta: false},
	{Kind: "cli", Description: "Command-line invocation output. Recorded by RunRecorder.CLICapture.", Usage: "RunRecorder.CLICapture()", IsMeta: false},
	{Kind: "log", Description: "Free-form log messages from the test run. Produced by rl.Printf().", Usage: "rl.Printf()", IsMeta: false},
	{Kind: "failure", Description: "Test assertion failure with structured details. Produced by rl.Failf().", Usage: "rl.Failf()", IsMeta: false},
	{Kind: "skip", Description: "Test was skipped via rl.Skipf().", Usage: "rl.Skipf()", IsMeta: false},
	{Kind: "gantt", Description: "Agent/step timeline as a gantt chart.", Usage: "rl.Gantt()", IsMeta: false},
	{Kind: "http_call", Description: "HTTP request/response with method, url, status, and body.", Usage: "RunRecorder.HTTPCall()", IsMeta: false},
	{Kind: "artifact", Description: "Test artifact (screenshot, trace) rendered inline in UI.", Usage: "rl.Event(\"artifact\", ...)", IsMeta: false},
	{Kind: "state_change", Description: "Run state transitions (test started/finished).", Usage: "Auto by NewRunLog / Close", IsMeta: true},
	{Kind: "tag", Description: "Run-level tags. Set via rl.Tag().", Usage: "rl.Tag()", IsMeta: true},
	{Kind: "token_usage", Description: "Per-call LLM token usage. Aggregated into run totals.", Usage: "rl.RecordTokenUsage()", IsMeta: true},
	{Kind: "metric", Description: "Performance/quality metrics.", Usage: "rl.Event(\"metric\", ...)", IsMeta: true},
}

func sectionID(id string) string { return "sdk-" + id }

func exampleDetailContent(raw string) string {
	if len(raw) > 500 {
		raw = raw[:500] + "\n... (truncated)"
	}
	if raw[0] == '{' || raw[0] == '[' {
		indented := ""
		depth := 0
		for _, ch := range raw {
			switch ch {
			case '{', '[':
				indented += string(ch) + "\n" + strings.Repeat("  ", depth+1)
				depth++
			case '}', ']':
				depth--
				indented += "\n" + strings.Repeat("  ", depth) + string(ch)
			case ',':
				indented += ",\n" + strings.Repeat("  ", depth)
			default:
				indented += string(ch)
			}
		}
		return indented
	}
	return raw
}

func exampleKindIntent(kind string) ui.BadgeIntent {
	switch kind {
	case "state_change":
		return ui.BadgeInfo
	case "section":
		return ui.BadgePrimary
	case "cli":
		return ui.BadgeWarning
	case "failure":
		return ui.BadgeError
	case "http_call":
		return ui.BadgeAccent
	default:
		return ui.BadgeNeutral
	}
}

templ renderExampleEvents(events []runlog.EventRow) {
	@table.TableWithProps(table.TableProps{Size: "sm", Bordered: true}) {
		@table.TableHead() {
			@table.TableHeadRow() {
				<th class="text-xs font-semibold text-base-content/60 uppercase text-right w-12">Seq</th>
				<th class="text-xs font-semibold text-base-content/60 uppercase">Kind</th>
				<th class="text-xs font-semibold text-base-content/60 uppercase">Message</th>
				<th class="text-xs font-semibold text-base-content/60 uppercase text-right w-20">Elapsed</th>
				<th class="text-xs font-semibold text-base-content/60 uppercase text-center w-8"></th>
			}
		}
		@table.TableBody() {
			for _, e := range events {
				@exampleEventRow(e)
				for _, c := range e.Children {
					@exampleChildRow(c)
				}
			}
		}
	}
}

templ exampleEventRow(e runlog.EventRow) {
	if e.Details != nil && *e.Details != "" && *e.Details != "{}" {
		<!-- lint:allow-raw -->
		<tr class="hover cursor-pointer" data-detail-id={ "detail-" + fmt.Sprintf("%d", e.Seq) }>
			<!-- lint:allow-raw -->
			<td class="text-right w-12">{ fmt.Sprintf("%d", e.Seq) }</td>
			<td>
				@ui.Badge(ui.BadgeProps{Label: e.Kind, Variant: exampleKindIntent(e.Kind), Size: ui.BadgeSizeSM})
			</td>
			<td>{ truncateMessage(e.Message, 80) }</td>
			<!-- lint:allow-raw -->
			<td class="text-right w-20">{ fmtElapsed(e.ElapsedS) }</td>
			<!-- lint:allow-raw -->
			<td class="text-center w-8"><span class="text-base-content/30 text-xs">▼</span></td>
		</tr>
		<!-- lint:allow-raw -->
		<tr id={ "detail-" + fmt.Sprintf("%d", e.Seq) } class="hidden">
			<!-- lint:allow-raw -->
			<td colspan="5" class="bg-base-200 p-3">
				<pre class="text-xs font-mono leading-relaxed text-base-content/70 whitespace-pre-wrap">{ exampleDetailContent(*e.Details) }</pre>
			</td>
		</tr>
	} else {
		<!-- lint:allow-raw -->
		<tr class="hover">
			<!-- lint:allow-raw -->
			<td class="text-right w-12">{ fmt.Sprintf("%d", e.Seq) }</td>
			<td>
				@ui.Badge(ui.BadgeProps{Label: e.Kind, Variant: exampleKindIntent(e.Kind), Size: ui.BadgeSizeSM})
			</td>
			<td>{ truncateMessage(e.Message, 80) }</td>
			<!-- lint:allow-raw -->
			<td class="text-right w-20">{ fmtElapsed(e.ElapsedS) }</td>
			<!-- lint:allow-raw -->
			<td class="text-center w-8"></td>
		</tr>
	}
}

templ exampleChildRow(c runlog.ChildEvent) {
	<!-- lint:allow-raw -->
	<tr class="text-base-content/60 text-sm">
		<!-- lint:allow-raw -->
		<td></td>
		<td><span class="text-xs ml-2">⊢ { c.Kind }</span></td>
		<!-- lint:allow-raw -->
		<td class="italic">{ truncateMessage(c.Message, 76) }</td>
		<!-- lint:allow-raw -->
		<td class="text-right w-20">{ fmtElapsed(c.ElapsedS) }</td>
		<!-- lint:allow-raw -->
		<td></td>
	</tr>
}

templ SDKPage() {
	@AppPage(fmt.Sprintf("Runlog - %s - SDK Reference", appName()), sidebarGroups) {
		@styleTag(sdkPageCSS)
		<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"/>
		@scriptTag(sdkPageJS)
		<script>hljs.highlightAll();</script>
		<div data-testid="sdk-reference-page" class="sdk-page">
			@layout.ViewMenu() {
				@layout.ViewMenuLabel("Helpers")
				for _, ex := range codeExamples {
					<a class="menu-item" href={ "#" + sectionID(ex.ID) }><span class="grow truncate">{ ex.Title }</span></a>
				}
				@layout.ViewMenuLabel("Reference")
				<a class="menu-item" href="#sdk-event-kinds"><span class="grow truncate">Event Kinds</span></a>
			}
			<div>
				<h1 class="text-2xl font-bold mb-2">SDK Reference</h1>
				<p class="text-base-content/60 mb-8">Code examples with sample event output. Click ▼ to expand event details.</p>
				for _, ex := range codeExamples {
					<div id={ sectionID(ex.ID) } class="mb-8 pb-6 px-4 border-b border-base-200 scroll-mt-4">
						<div class="mb-3">
							<h2 class="text-base font-semibold">{ ex.Title }</h2>
							<p class="text-xs text-base-content/50 mt-0.5">{ ex.Description }</p>
						</div>
						<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
							@ui.CodePreview([]ui.CodeTab{{Label: ex.Lang, Lang: ex.Lang, Code: ex.Code}})
							<div>
								if len(ex.Events) > 0 {
									<div class="text-xs font-semibold text-base-content/40 uppercase tracking-wider mb-2">Event output</div>
									@renderExampleEvents(ex.Events)
								}
							</div>
						</div>
					</div>
				}
				<div id="sdk-event-kinds" class="mt-8 p-4 bg-base-200 rounded-box border border-base-content/10 scroll-mt-4">
					<h2 class="text-md font-semibold mb-2">Event Kinds Reference</h2>
					<p class="text-sm text-base-content/60 mb-4">All event kinds produced by the helpers above.</p>
					@eventsReferenceTable()
				</div>
			</div>
		</div>
	}
}

templ SDKContent() {
	@styleTag(sdkPageCSS)
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/styles/github-dark.min.css"/>
	<script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.9.0/highlight.min.js"></script>
	@scriptTag(sdkPageJS)
	<script>hljs.highlightAll();</script>
	<div data-testid="sdk-reference-content" class="sdk-page">
		@layout.ViewMenu() {
			@layout.ViewMenuLabel("Helpers")
			for _, ex := range codeExamples {
				<a class="menu-item" href={ "#" + sectionID(ex.ID) }><span class="grow truncate">{ ex.Title }</span></a>
			}
			@layout.ViewMenuLabel("Reference")
			<a class="menu-item" href="#sdk-event-kinds"><span class="grow truncate">Event Kinds</span></a>
		}
		<div>
			<h1 class="text-2xl font-bold mb-2">SDK Reference</h1>
			<p class="text-base-content/60 mb-4">Code examples with sample event output. Click ▼ to expand event details.</p>
			for _, ex := range codeExamples {
				<div id={ "sdk-" + ex.ID } class="mb-8 pb-6 px-4 border-b border-base-200 scroll-mt-4">
					<div class="mb-3">
						<h2 class="text-base font-semibold">{ ex.Title }</h2>
						<p class="text-xs text-base-content/50 mt-0.5">{ ex.Description }</p>
					</div>
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
						@ui.CodePreview([]ui.CodeTab{{Label: ex.Lang, Lang: ex.Lang, Code: ex.Code}})
						<div>
							if len(ex.Events) > 0 {
								<div class="text-xs font-semibold text-base-content/40 uppercase tracking-wider mb-2">Event output</div>
								@renderExampleEvents(ex.Events)
							}
						</div>
					</div>
				</div>
			}
			<div id="sdk-event-kinds-inline" class="mt-8 p-4 bg-base-200 rounded-box border border-base-content/10 scroll-mt-4">
				<h2 class="text-md font-semibold mb-2">Event Kinds Reference</h2>
				<p class="text-sm text-base-content/60 mb-4">All event kinds produced by the helpers above.</p>
				@eventsReferenceTable()
			</div>
		</div>
	</div>
}

templ eventsReferenceTable() {
	@table.TableWithProps(table.TableProps{Size: "sm", Bordered: true}) {
		@table.TableHead() {
			@table.TableHeadRow() {
				@table.TableHeadCell("Kind")
				@table.TableHeadCell("Description")
				@table.TableHeadCell("Usage")
				<th class="text-xs font-semibold text-base-content/60 uppercase text-center w-16">Meta</th>
			}
		}
		@table.TableBody() {
			for _, ek := range eventKinds {
				<!-- lint:allow-raw -->
				<tr class="hover hover:bg-base-200 transition-colors">
					<td class="font-mono text-sm font-semibold">{ ek.Kind }</td>
					<td class="text-sm">{ ek.Description }</td>
					<td class="text-xs font-mono text-base-content/60">{ ek.Usage }</td>
					<td class="text-center">
						if ek.IsMeta {
							<span class="badge badge-ghost badge-xs">yes</span>
						} else {
							<span class="text-base-content/30">—</span>
						}
					</td>
				</tr>
			}
		}
	}
}
