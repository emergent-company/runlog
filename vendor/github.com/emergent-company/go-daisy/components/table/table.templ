package table

import (
	"strconv"

	"github.com/emergent-company/go-daisy/devmode"
)

// SortDir indicates the current sort direction.
type SortDir string

const (
	SortAsc  SortDir = "asc"
	SortDesc SortDir = "desc"
	SortNone SortDir = ""
)

// TableProps configures the appearance of a TableWithProps component.
type TableProps struct {
	// Size controls the DaisyUI size modifier: "xs", "sm", "md" (default/empty), "lg", "xl".
	Size string
	// Striped adds table-zebra for alternating row colours.
	Striped bool
	// PinRows makes <thead> and <tfoot> rows sticky (table-pin-rows).
	PinRows bool
	// PinCols makes <th> columns sticky (table-pin-cols).
	PinCols bool
	// Bordered wraps the table with a rounded border (rounded-box border border-base-content/5 bg-base-100).
	Bordered bool
	// Attrs are optional extra HTML attributes on the outer wrapper div, e.g. {"data-testid": "users-table"}.
	Attrs templ.Attributes
}

// tableClasses builds the DaisyUI class string from TableProps.
func tableClasses(props TableProps) string {
	cls := "table w-full"
	switch props.Size {
	case "xs":
		cls += " table-xs"
	case "sm":
		cls += " table-sm"
	case "lg":
		cls += " table-lg"
	case "xl":
		cls += " table-xl"
	}
	if props.Striped {
		cls += " table-zebra"
	}
	if props.PinRows {
		cls += " table-pin-rows"
	}
	if props.PinCols {
		cls += " table-pin-cols"
	}
	return cls
}

// Table renders a DaisyUI table wrapper with zebra striping.
templ Table() {
	<div class="overflow-x-auto rounded-md bg-base-100" { devmode.Attrs(ctx, "table/Table")... }>
		<table class="table table-zebra w-full">
			{ children... }
		</table>
	</div>
}

// TableWithProps renders a DaisyUI table with a canonical wrapper.
templ TableWithProps(props TableProps) {
	if props.Bordered {
		<div class="overflow-x-auto rounded-box border border-base-content/5 bg-base-100" { devmode.Attrs(ctx, "table/TableWithProps")... } { props.Attrs... }>
			<table class={ tableClasses(props) }>
				{ children... }
			</table>
		</div>
	} else {
		<div class="overflow-x-auto" { devmode.Attrs(ctx, "table/TableWithProps")... } { props.Attrs... }>
			<table class={ tableClasses(props) }>
				{ children... }
			</table>
		</div>
	}
}

// TableHead renders a <thead> wrapper accepting head-row children.
// Note: data-component is intentionally omitted on table structural elements
// (<thead>, <tbody>, <tr>, <th>, <td>) to avoid browser table-parsing issues.
templ TableHead() {
	<thead>
		{ children... }
	</thead>
}

// TableHeadRow renders a <tr> inside a <thead>.
templ TableHeadRow() {
	<tr>
		{ children... }
	</tr>
}

// TableHeadCell renders a plain (non-sortable) <th> column header.
templ TableHeadCell(label string) {
	<th class="text-xs font-semibold text-base-content/60 uppercase">{ label }</th>
}

// TableBody renders a <tbody> wrapper accepting row children.
templ TableBody() {
	<tbody>
		{ children... }
	</tbody>
}

// TableEmpty renders a full-width empty-state row inside a <tbody>.
templ TableEmpty(colspan int, message string) {
	<tr>
		<td colspan={ strconv.Itoa(max(colspan, 1)) } class="text-center text-base-content/60 py-8">{ message }</td>
	</tr>
}

// TableRow renders a <tr> with an optional id and hover highlight.
// attrs is optional; pass nil when not needed.
templ TableRow(id string, hover bool, attrs templ.Attributes) {
	<tr
		if id != "" {
			id={ id }
		}
		class={ templ.KV("hover", hover) }
		{ attrs... }
	>
		{ children... }
	</tr>
}

// TableCell renders a <td> with an optional extra CSS class.
// attrs is optional; pass nil when not needed.
templ TableCell(class string, attrs templ.Attributes) {
	<td class={ class } { attrs... }>
		{ children... }
	</td>
}

// TableActionCell renders a right-aligned <td> for action menus.
templ TableActionCell() {
	<td class="text-right">
		{ children... }
	</td>
}

// TableHeader renders a <th> cell that is optionally sortable.
templ TableHeader(label string, sortKey string, currentSortKey string, currentDir SortDir, baseURL string) {
	if sortKey == "" {
		<th class="text-xs font-semibold text-base-content/60 uppercase">{ label }</th>
	} else {
		<th class="text-xs font-semibold text-base-content/60 uppercase">
			<a
				class="flex items-center gap-1 hover:text-base-content cursor-pointer"
				href={ templ.URL(sortURL(baseURL, sortKey, currentSortKey, currentDir)) }
				hx-get={ sortURL(baseURL, sortKey, currentSortKey, currentDir) }
				hx-target="closest table"
				hx-swap="outerHTML"
			>
				{ label }
				if currentSortKey == sortKey {
					if currentDir == SortAsc {
					<span class="iconify lucide--chevron-up size-3" aria-hidden="true"></span>
				} else {
						<span class="iconify lucide--chevron-down size-3" aria-hidden="true"></span>
					}
				}
			</a>
		</th>
	}
}

// sortURL builds a URL for toggling sort direction.
func sortURL(base string, key string, currentKey string, currentDir SortDir) string {
	dir := "asc"
	if currentKey == key && currentDir == SortAsc {
		dir = "desc"
	}
	return base + "&sort=" + key + "&dir=" + dir
}
