package form

import (
	"github.com/emergent-company/go-daisy/devmode"
)

// RichTextEditorTheme represents the Quill editor theme.
type RichTextEditorTheme string

const (
	QuillThemeSnow   RichTextEditorTheme = "snow"
	QuillThemeBubble RichTextEditorTheme = "bubble"
)

// RichTextEditorProps configures a Quill rich text editor.
type RichTextEditorProps struct {
	ID          string
	Label       string
	Value       string // initial HTML content
	Placeholder string
	Theme       RichTextEditorTheme
	ReadOnly    bool
	Height      string // e.g. "200px", "300px"
	Attrs       templ.Attributes
}

// RichTextEditor renders a Quill rich text editor.
templ RichTextEditor(props RichTextEditorProps) {
	<div class="form-control w-full" { devmode.Attrs(ctx, "form/RichTextEditor")... }>
		if props.Label != "" {
			<label class="label" for={ props.ID }>
				<span class="label-text">{ props.Label }</span>
			</label>
		}
		<div
			id={ props.ID }
			data-quill
			data-theme={ string(props.Theme) }
			data-placeholder={ props.Placeholder }
			data-readonly={ ternary(props.ReadOnly, "true", "false") }
			data-value={ props.Value }
			style={ "height:" + props.Height }
			class="rounded-box border border-base-content/10"
			{ props.Attrs... }
		></div>
	</div>
	@quillScript()
}

templ quillScript() {
	<script>
	if (!window._quillInit) {
	  window._quillInit = true;

	  window.initQuill = function(el) {
	    if (typeof Quill === 'undefined') {
	      var s = document.createElement('script');
	      s.src = 'https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.min.js';
	      s.onload = function() { initQuillElement(el); };
	      document.head.appendChild(s);
	      var l = document.createElement('link');
	      l.rel = 'stylesheet';
	      l.href = 'https://cdn.jsdelivr.net/npm/quill@2.0.3/dist/quill.' + (el.dataset.theme || 'snow') + '.css';
	      document.head.appendChild(l);
	    } else {
	      initQuillElement(el);
	    }
	  };

	  function initQuillElement(el) {
	    if (el._quill) return;
	    try {
	      var theme = el.dataset.theme || 'snow';
	      var placeholder = el.dataset.placeholder || 'Write something...';
	      el._quill = new Quill(el, {
	        theme: theme,
	        placeholder: placeholder,
	        readOnly: el.dataset.readonly === 'true',
	        modules: theme === 'snow' ? {
	          toolbar: [
	            [{ 'header': [1,2,3,false] }],
	            ['bold','italic','underline','strike'],
	            [{ 'list': 'ordered' }, { 'list': 'bullet' }],
	            ['link','image','code-block'],
	            ['clean']
	          ]
	        } : undefined
	      });
	      // Set initial content
	      var val = el.dataset.value;
	      if (val) {
	        try { el._quill.clipboard.dangerouslyPasteHTML(val); } catch(e) {}
	      }
	      // Sync to hidden input on change
	      var hidden = document.getElementById(el.id + '-hidden');
	      if (!hidden) {
	        hidden = document.createElement('input');
	        hidden.type = 'hidden';
	        hidden.name = el.id;
	        hidden.id = el.id + '-hidden';
	        el.parentNode.appendChild(hidden);
	      }
	      el._quill.on('text-change', function() {
	        hidden.value = el._quill.root.innerHTML;
	      });
	    } catch(e) { console.warn('Quill init failed:', e); }
	  }

	  document.addEventListener('DOMContentLoaded', function() {
	    document.querySelectorAll('[data-quill]').forEach(initQuillElement);
	  });
	  document.addEventListener('htmx:after:settle', function() {
	    document.querySelectorAll('[data-quill]:not(._ql-initialized)').forEach(function(el) {
	      el.classList.add('_ql-initialized');
	      initQuillElement(el);
	    });
	  });
	}
	</script>
}
