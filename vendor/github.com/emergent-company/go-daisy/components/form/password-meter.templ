package form

import (
	"strconv"

	"github.com/emergent-company/go-daisy/devmode"
	ui "github.com/emergent-company/go-daisy/components/ui"
)

// PasswordMeterProps configures a password input with strength meter.
type PasswordMeterProps struct {
	Name        string
	Label       string
	Value       string
	Placeholder string
	Required    bool
	Disabled    bool
	Error       string
	Class       string
	ShowToggle  bool
	MinLength   int
	Attrs       templ.Attributes
}

// PasswordMeter renders a password input with a strength progress bar.
templ PasswordMeter(props PasswordMeterProps) {
	@Field(props.Label, props.Name, props.Error) {
		<div class="join w-full" { devmode.Attrs(ctx, "form/PasswordMeter")... }>
			<input
				id={ props.Name }
				name={ props.Name }
				type="password"
				value={ props.Value }
				placeholder={ props.Placeholder }
				required?={ props.Required }
				disabled?={ props.Disabled }
				if props.MinLength > 0 {
					minlength={ strconv.Itoa(props.MinLength) }
				}
				class={ "input input-bordered join-item flex-1",
					templ.KV("input-error", props.Error != ""),
					props.Class }
				oninput="updatePasswordMeter(this)"
				{ props.Attrs... }
			/>
			if props.ShowToggle {
				<button
					type="button"
					class="btn btn-outline join-item btn-square"
					onclick="togglePasswordVisibility(this)"
					aria-label="Toggle password visibility"
				>
					@ui.IconSpan("lucide--eye", "size-4")
				</button>
			}
		</div>
		<div id={ props.Name + "-meter" } class="flex items-center gap-2 mt-2">
			<progress
				id={ props.Name + "-progress" }
				class="progress progress-ghost flex-1 h-2"
				value="0"
				max="4"
			></progress>
			<span id={ props.Name + "-label" } class="text-xs text-base-content/50 w-16 text-right">Weak</span>
		</div>
	}
	@passwordMeterScript()
}

templ passwordMeterScript() {
	<script>
	if (!window._pwMeterInit) {
	  window._pwMeterInit = true;

	  window.togglePasswordVisibility = function(btn) {
	    var input = btn.closest('.join').querySelector('input');
	    if (!input) return;
	    if (input.type === 'password') {
	      input.type = 'text';
	      btn.querySelector('.iconify').classList.remove('lucide--eye');
	      btn.querySelector('.iconify').classList.add('lucide--eye-off');
	    } else {
	      input.type = 'password';
	      btn.querySelector('.iconify').classList.remove('lucide--eye-off');
	      btn.querySelector('.iconify').classList.add('lucide--eye');
	    }
	  };

	  window.updatePasswordMeter = function(input) {
	    var val = input.value;
	    var score = 0;
	    if (val.length >= 8) score++;
	    if (val.length >= 12) score++;
	    if (/[A-Z]/.test(val) && /[a-z]/.test(val)) score++;
	    if (/\d/.test(val) && /[^A-Za-z0-9]/.test(val)) score++;

	    var meter = document.getElementById(input.name + '-progress');
	    var label = document.getElementById(input.name + '-label');
	    if (!meter || !label) return;

	    meter.value = score;
	    var colors = ['progress-ghost', 'progress-error', 'progress-warning', 'progress-info', 'progress-success'];
	    for (var i = 0; i < colors.length; i++) meter.classList.toggle(colors[i], i === score);
	    var labels = ['Weak', 'Fair', 'Good', 'Strong', 'Very strong'];
	    label.textContent = labels[score] || 'Weak';
	  };
	}
	</script>
}
