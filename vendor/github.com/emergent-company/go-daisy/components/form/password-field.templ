package form

import (
	"github.com/emergent-company/go-daisy/devmode"
	ui "github.com/emergent-company/go-daisy/components/ui"
)

// PasswordFieldProps configures a password input with show/hide toggle.
type PasswordFieldProps struct {
	Name        string
	Label       string
	Value       string
	Placeholder string
	Required    bool
	Disabled    bool
	Error       string
	Class       string
	ShowToggle  bool // show/hide password visibility toggle
	Attrs       templ.Attributes
}

// PasswordField renders a labeled password input with optional show/hide toggle.
templ PasswordField(props PasswordFieldProps) {
	@Field(props.Label, props.Name, props.Error) {
		<div class="join w-full" { devmode.Attrs(ctx, "form/PasswordField")... }>
			<input
				id={ props.Name }
				name={ props.Name }
				type="password"
				value={ props.Value }
				placeholder={ props.Placeholder }
				required?={ props.Required }
				disabled?={ props.Disabled }
				class={ "input input-bordered join-item flex-1",
					templ.KV("input-error", props.Error != ""),
					props.Class }
				{ props.Attrs... }
			/>
			if props.ShowToggle {
				<button
					type="button"
					class="btn btn-outline join-item btn-square"
					onclick="togglePasswordVisibility(this)"
					aria-label="Toggle password visibility"
				>
					@ui.IconSpan("lucide--eye", "size-4")
				</button>
			}
		</div>
	}
	@passwordFieldScript()
}

templ passwordFieldScript() {
	<script>
	if (!window._pwFieldInit) {
	  window._pwFieldInit = true;
	  window.togglePasswordVisibility = function(btn) {
	    var input = btn.closest('.join').querySelector('input');
	    if (!input) return;
	    if (input.type === 'password') {
	      input.type = 'text';
	      btn.querySelector('.iconify').classList.remove('lucide--eye');
	      btn.querySelector('.iconify').classList.add('lucide--eye-off');
	    } else {
	      input.type = 'password';
	      btn.querySelector('.iconify').classList.remove('lucide--eye-off');
	      btn.querySelector('.iconify').classList.add('lucide--eye');
	    }
	  };
	}
	</script>
}
