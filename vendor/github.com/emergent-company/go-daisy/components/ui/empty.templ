package ui

import "github.com/emergent-company/go-daisy/devmode"

// Empty renders an empty-state placeholder: icon, title, description, optional CTA.
templ Empty(icon string, title string, description string) {
	<div class="flex flex-col items-center justify-center py-16 text-center px-4" { devmode.Attrs(ctx, "ui/Empty")... }>
		if icon != "" {
			<span class={ "iconify size-12 text-base-content/20 mb-4 " + icon }></span>
		}
		<h3 class="text-base font-semibold text-base-content mb-1">{ title }</h3>
		if description != "" {
			<p class="text-sm text-base-content/50 mb-4">{ description }</p>
		}
		{ children... }
	</div>
}
