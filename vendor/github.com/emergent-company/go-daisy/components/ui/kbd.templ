package ui

import "github.com/emergent-company/go-daisy/devmode"

// KbdSize controls the size of a keyboard key display.
type KbdSize string

const (
	KbdXS KbdSize = "kbd-xs"
	KbdSM KbdSize = "kbd-sm"
	KbdMD KbdSize = ""
	KbdLG KbdSize = "kbd-lg"
)

// Kbd renders a keyboard key display.
templ Kbd(size KbdSize) {
	<kbd class={ "kbd", templ.KV(string(size), size != "") } { devmode.Attrs(ctx, "ui/Kbd")... }>
		{ children... }
	</kbd>
}
