package nav

import (
	"strconv"

	ui "github.com/emergent-company/go-daisy/components/ui"
	"github.com/emergent-company/go-daisy/devmode"
)

// ProfileMenuItem is a single item in the profile dropdown menu.
type ProfileMenuItem struct {
	// Label is the display text.
	Label string
	// Href is the link target.
	Href string
	// Icon is the Iconify icon identifier (e.g. "lucide--user").
	Icon string
	// Badge is an optional numeric badge count shown after the label.
	Badge int
	// Danger renders the item in error colour (for sign-out etc.).
	Danger bool
}

// ProfileMenu renders an avatar dropdown with user info, grouped menu items,
// and a sign-out action at the bottom.
//
// items before the divider are regular menu items; signOutHref adds the
// dedicated sign-out row.
templ ProfileMenu(name, email, initials string, items []ProfileMenuItem, signOutHref string) {
	<div class="dropdown dropdown-bottom dropdown-end" { devmode.Attrs(ctx, "nav/ProfileMenu")... }>
		<div tabindex="0" class="avatar bg-base-200 size-12 cursor-pointer overflow-hidden rounded-full">
			<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-lg">
				{ initials }
			</div>
		</div>
		<div tabindex="0" class="dropdown-content bg-base-100 rounded-box mt-2 w-56 shadow-lg border border-base-200">
			<div class="px-4 py-3 border-b border-base-200">
				<p class="font-semibold text-sm">{ name }</p>
				<p class="text-base-content/60 text-xs mt-0.5">{ email }</p>
			</div>
			<ul class="menu w-full p-2">
				for _, item := range items {
					<li>
						<a
							href={ templ.SafeURL(item.Href) }
							class={ templ.KV("text-error hover:bg-error/10", item.Danger) }
						>
							if item.Icon != "" {
								@ui.IconSpan(item.Icon, "size-4")
							}
							<span>{ item.Label }</span>
							if item.Badge > 0 {
								<span class="badge badge-sm badge-primary">{ strconv.Itoa(item.Badge) }</span>
							}
						</a>
					</li>
				}
			</ul>
			if signOutHref != "" {
				<hr class="border-base-200"/>
				<ul class="menu w-full p-2">
					<li>
						<a class="text-error hover:bg-error/10" href={ templ.SafeURL(signOutHref) }>
							@ui.IconSpan("lucide--log-out", "size-4")
							<span>Sign Out</span>
						</a>
					</li>
				</ul>
			}
		</div>
	</div>
}

type ProfileAccount struct {
	Name   string
	Email  string
	Avatar string
	Active bool
}

type ProfileMenuVariantOpts struct {
	Name      string
	Email     string
	Initials  string
	Role      string
	Accounts  []ProfileAccount
	Items     []ProfileMenuItem
	SignOutHref string
}

templ ProfileMenuVariant(style string, opts ProfileMenuVariantOpts) {
	switch style {
	case "default":
		@ProfileMenu(opts.Name, opts.Email, opts.Initials, opts.Items, opts.SignOutHref)

	case "switch-account":
		<div class="dropdown dropdown-bottom dropdown-end" { devmode.Attrs(ctx, "nav/ProfileMenuVariant")... }>
			<div tabindex="0" class="avatar bg-base-200 size-12 cursor-pointer overflow-hidden rounded-full">
				<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-lg">{ opts.Initials }</div>
			</div>
			<div tabindex="0" class="dropdown-content bg-base-100 rounded-box mt-2 w-64 shadow-lg border border-base-200">
				<div class="border-base-200 border-b p-4">
					<div class="flex items-center justify-between">
						<div class="flex items-center gap-3">
							<div class="avatar bg-base-200 size-10 rounded-full overflow-hidden">
								<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold">{ opts.Initials }</div>
							</div>
							<div>
								<p class="font-semibold text-sm">{ opts.Name }</p>
								<p class="text-base-content/60 text-xs">{ opts.Email }</p>
								if opts.Role != "" {
									@ui.Badge(ui.BadgeProps{Label: opts.Role, Variant: ui.BadgePrimary, Style: ui.BadgeStyleSoft, Size: ui.BadgeSizeXS, Attrs: templ.Attributes{"class": "mt-0.5"}})
								}
							</div>
						</div>
					</div>
					<div class="mt-3 flex gap-2">
						@ui.Button(ui.ButtonProps{Type: ui.ButtonTypeButton, Variant: ui.ButtonPrimary, Size: ui.ButtonXS, ExtraClass: "grow"}){ "Account" }
						@ui.Button(ui.ButtonProps{Type: ui.ButtonTypeButton, Variant: ui.ButtonOutline, Size: ui.ButtonXS, ExtraClass: "border-base-300 grow"}){ "Sign Out" }
					</div>
				</div>
				<div class="px-2 pt-2 pb-1">
					<p class="menu-label text-[11px] px-2 pb-1">Switch Account</p>
					for _, acct := range opts.Accounts {
						<div class="hover:bg-base-200 flex cursor-pointer items-center gap-3 rounded-lg px-2 py-2 transition-colors">
							<div class="avatar bg-base-200 size-8 rounded-full overflow-hidden">
								<div class="bg-base-300 text-base-content/80 flex size-full items-center justify-center font-semibold text-xs">{ firstChars(acct.Name, 2) }</div>
							</div>
							<div class="grow">
								<p class="text-sm font-medium">{ acct.Name }</p>
								<p class="text-base-content/60 text-xs">{ acct.Email }</p>
							</div>
							if acct.Active {
								@ui.IconSpan("lucide--check", "size-4 text-primary")
							}
						</div>
					}
				</div>
				<hr class="border-base-200 mx-2" />
				<ul class="menu w-full p-2">
					<li><div>@ui.IconSpan("lucide--user-plus", "size-4"){ "Add New Account" }</div></li>
				</ul>
				<hr class="border-base-200 mx-2" />
				<ul class="menu w-full p-2">
					<li><div class="text-base-content/60 text-xs">Version 3.0.0</div></li>
				</ul>
			</div>
		</div>

	case "overlay":
		<div class="dropdown dropdown-bottom dropdown-end" { devmode.Attrs(ctx, "nav/ProfileMenuVariant")... }>
			<div tabindex="0" class="flex cursor-pointer items-center gap-2">
				<div class="avatar bg-base-200 size-8 rounded-full overflow-hidden">
					<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-sm">{ opts.Initials }</div>
				</div>
				<div class="max-md:hidden">
					<p class="text-sm font-medium leading-tight">{ opts.Name }</p>
					<p class="text-base-content/60 text-xs leading-tight">{ opts.Email }</p>
				</div>
				@ui.IconSpan("lucide--chevron-down", "size-3.5 text-base-content/40 max-md:hidden")
			</div>
			<div tabindex="0" class="dropdown-content bg-base-100 rounded-box mt-2 w-56 shadow-lg border border-base-200">
				<div class="p-4 text-center">
					<div class="avatar bg-base-200 size-16 mx-auto rounded-full overflow-hidden">
						<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-2xl">{ opts.Initials }</div>
					</div>
					<div class="mt-2">
						<div class="inline-flex items-center gap-1 badge badge-soft badge-primary badge-xs">Shield verified</div>
					</div>
					<p class="mt-2 font-semibold">{ opts.Name }</p>
					<p class="text-base-content/60 text-xs">{ opts.Email }</p>
				</div>
				<hr class="border-base-200" />
				<ul class="menu w-full p-2">
					<li><a>@ui.IconSpan("lucide--settings", "size-4"){ "Preferences" }</a></li>
					<li><a>@ui.IconSpan("lucide--files", "size-4"){ "My Files" }</a></li>
					<li><a>@ui.IconSpan("lucide--layers", "size-4"){ "Collections" }</a></li>
				</ul>
				<hr class="border-base-200" />
				<ul class="menu w-full p-2">
					<li><a class="text-error hover:bg-error/10">@ui.IconSpan("lucide--log-out", "size-4"){ "Log Out" }</a></li>
				</ul>
			</div>
		</div>

	case "referral":
		<div class="dropdown dropdown-bottom dropdown-end" { devmode.Attrs(ctx, "nav/ProfileMenuVariant")... }>
			<div tabindex="0" class="avatar bg-base-200 size-12 cursor-pointer overflow-hidden rounded-full">
				<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-lg">{ opts.Initials }</div>
			</div>
			<div tabindex="0" class="dropdown-content bg-base-100 rounded-box mt-2 w-56 shadow-lg border border-base-200">
				<div class="border-base-200 border-b p-4">
					<div class="flex items-center gap-3">
						<div class="avatar bg-base-200 size-10 rounded-full overflow-hidden">
							<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold">{ opts.Initials }</div>
						</div>
						<div>
							<p class="font-semibold text-sm">{ opts.Name }</p>
							<p class="text-base-content/60 text-xs">{ opts.Email }</p>
						</div>
					</div>
				</div>
				<ul class="menu w-full p-2">
					<li><a>@ui.IconSpan("lucide--gift", "size-4"){ "My Referrals" }</a></li>
					<li><a>@ui.IconSpan("lucide--award", "size-4"){ "Referral Rewards" }</a></li>
					<li><a>@ui.IconSpan("lucide--clock", "size-4"){ "Pending Invitations" }@ui.Badge(ui.BadgeProps{Label: "3", Variant: ui.BadgeWarning, Style: ui.BadgeStyleSoft, Size: ui.BadgeSizeSM})</a></li>
				</ul>
				<hr class="border-base-200" />
				<div class="p-3">
					<div class="bg-base-200 rounded-box flex items-center gap-3 p-3">
						<div class="bg-primary/10 rounded-box flex size-10 items-center justify-center">
							@ui.IconSpan("lucide--user-plus", "size-5 text-primary")
						</div>
						<div>
							<p class="font-medium text-sm">Refer a friend</p>
							<p class="text-base-content/60 text-xs">5 invites waiting</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	}
}

// firstChars returns the first n characters of a string.
func firstChars(s string, n int) string {
	runes := []rune(s)
	if len(runes) < n {
		return string(runes)
	}
	return string(runes[:n])
}
