package layout

import (
	"strconv"

	"github.com/emergent-company/go-daisy/components/ui"
	"github.com/emergent-company/go-daisy/devmode"
)



templ SidebarFoldToggle() {
	<label for="_layout-sidebar-toggle-trigger" title="Toggle sidebar" class="btn btn-circle btn-ghost btn-sm text-base-content/50 relative max-lg:hidden">
		@ui.IconSpan("lucide--panel-left-close", "absolute size-4.5 opacity-100 transition-all duration-300 group-has-[[id=_layout-sidebar-hover-trigger]:checked]/html:opacity-0")
		@ui.IconSpan("lucide--panel-left-dashed", "absolute size-4.5 opacity-0 transition-all duration-300 group-has-[[id=_layout-sidebar-hover-trigger]:checked]/html:opacity-100")
	</label>
}

templ SidebarSimpleToggle() {
	<label for="_layout-sidebar-toggle-trigger" title="Toggle sidebar" class="btn btn-circle btn-ghost btn-sm text-base-content/50 max-lg:hidden">
		@ui.IconSpan("lucide--panel-left-close", "size-4.5")
	</label>
}

templ SidebarMenuLabel(label string) {
	<p class="menu-label px-2.5 pb-1.5">{ label }</p>
}

templ SidebarMenuItem(label string, href string, icon string, active bool) {
	<a class={ "menu-item", templ.KV("active", active) } href={ templ.SafeURL(href) } { devmode.Attrs(ctx, "layout/SidebarMenuItem")... }>
		if icon != "" {
			<span class={ "iconify size-4 " + icon }></span>
		}
		<span class="grow">{ label }</span>
	</a>
}

templ SidebarMenuItemWithExtra(label string, href string, icon string, active bool) {
	<a class={ "menu-item", templ.KV("active", active) } href={ templ.SafeURL(href) } { devmode.Attrs(ctx, "layout/SidebarMenuItem")... }>
		if icon != "" {
			<span class={ "iconify size-4 " + icon }></span>
		}
		<span class="grow">{ label }</span>
		{ children... }
	</a>
}

templ SidebarBadge(count int) {
	<div class="bg-secondary text-secondary-content rounded-box ms-0 px-1.5 text-[12px]">{ strconv.Itoa(count) }</div>
}

templ SidebarCollapsible(icon string, label string, children []templ.Component, open bool) {
	<div class="group collapse" { devmode.Attrs(ctx, "layout/SidebarCollapsible")... }>
		<input aria-label="Sidemenu item trigger" class="peer" type="checkbox" { checkedAttr(open) }/>
		<div class="collapse-title px-2.5 py-1.5">
			if icon != "" {
				<span class={ "iconify size-4 " + icon }></span>
			}
			<span class="grow">{ label }</span>
			@ui.IconSpan("lucide--chevron-right", "arrow-icon size-3.5")
		</div>
		<div class="collapse-content ms-6.5 !p-0">
			<div class="mt-0.5 space-y-0.5">
				for _, c := range children {
					@c
				}
			</div>
		</div>
	</div>
}

templ SidebarAvatarDropdown(avatarSrc string, avatarAlt string) {
	<div class="dropdown dropdown-bottom dropdown-end" { devmode.Attrs(ctx, "layout/SidebarAvatarDropdown")... }>
		<div tabindex="0">
			<div class="avatar bg-base-200 size-8 cursor-pointer overflow-hidden rounded-full">
				if avatarSrc != "" {
					<img alt={ avatarAlt } src={ avatarSrc }/>
				} else {
					<div class="bg-primary text-primary-content flex size-full items-center justify-center font-semibold text-sm">U</div>
				}
			</div>
		</div>
		<div tabindex="0" class="dropdown-content bg-base-100 rounded-box mt-4 w-44 shadow">
			<ul class="menu w-full p-2">
				<li><a href="#">@ui.IconSpan("lucide--user", "size-4") My Profile</a></li>
				<li><a href="#">@ui.IconSpan("lucide--settings", "size-4") Settings</a></li>
				<li><a href="#">@ui.IconSpan("lucide--help-circle", "size-4") Help</a></li>
			</ul>
			<hr class="border-base-300"/>
			<ul class="menu w-full p-2">
				<li><div>@ui.IconSpan("lucide--arrow-left-right", "size-4") Switch Account</div></li>
				<li><a class="text-error hover:bg-error/10" href="#">@ui.IconSpan("lucide--log-out", "size-4") Logout</a></li>
			</ul>
		</div>
	</div>
}

templ SidebarPromoCard(daysLeft int, message string) {
	<div class="border-base-200 rounded-box relative mx-3 mb-3 mt-auto border p-3">
		<p class="font-medium">{ sprintTrial(daysLeft) } Days left!</p>
		<progress class="progress progress-warning h-1 align-super" max="100" value={ sprintTrialProgress(daysLeft) }></progress>
		<p class="text-base-content/80 -mt-1.5 text-sm leading-tight">
			if message != "" {
				{ message }
			} else {
				Trial ending soon. Upgrade to stay active.
			}
		</p>
		@ui.Button(ui.ButtonProps{Size: ui.ButtonXS, Style: ui.ButtonStyleSoft, Shape: ui.ButtonShapeCircle, ExtraClass: "absolute end-2 top-2", Attrs: templ.Attributes{"aria-label": "Close"}}){
			@ui.IconSpan("lucide--x", "size-3.5")
		}
	</div>
}

templ SidebarSearchInput(placeholder string, showKbd bool) {
	<div class="input input-sm w-full border-base-300">
		@ui.IconSpan("lucide--search", "size-3.5 text-base-content/60")
		<input class="grow" placeholder={ placeholder } aria-label="Search" type="search"/>
		if showKbd {
			<div class="border-base-300 bg-base-200 rounded-box px-1 text-[10px]">{ "\u2318K" }</div>
		}
	</div>
}

templ SidebarProjectSwitcher(items []SidebarProjectItem) {
	<div class="dropdown w-full">
		<label tabindex="0" class="btn btn-outline border-base-300 btn-sm w-full justify-between gap-2 font-normal">
			@ui.IconSpan("lucide--layers", "size-3.5 text-base-content/60")
			<span class="grow text-left truncate text-sm">{ firstItem(items).Name }</span>
			@ui.IconSpan("lucide--chevron-down", "size-3.5 text-base-content/40")
		</label>
		<ul tabindex="0" class="dropdown-content menu menu-sm bg-base-100 rounded-box shadow-lg z-50 w-full p-1 border border-base-content/10 mt-1">
			for _, item := range items {
				<li><a href={ templ.SafeURL(item.Href) }><span class={ "iconify size-4 " + item.Icon }></span>{ item.Name }</a></li>
			}
		</ul>
	</div>
}

templ SidebarMeetingBar(participants []string, meetingLabel string) {
	<div class="border-base-200 mx-3 mb-3 mt-auto rounded-box border p-3">
		<div class="flex items-center gap-2">
			<div class="flex -space-x-2">
				for _, p := range participants {
					<div class="avatar bg-base-200 size-7 rounded-full border-2 border-base-100 overflow-hidden">
						<div class="bg-primary text-primary-content flex size-full items-center justify-center text-[10px] font-semibold">{ initialsFrom(p) }</div>
					</div>
				}
			</div>
			<div>
				<p class="text-xs font-medium">In Meeting</p>
				<p class="text-base-content/60 text-[10px]">{ meetingLabel }</p>
			</div>
		</div>
		<div class="mt-2 flex gap-2">
			@ui.Button(ui.ButtonProps{Variant: ui.ButtonPrimary, Size: ui.ButtonXS, Style: ui.ButtonStyleSoft, ExtraClass: "gap-1"}){ @ui.IconSpan("lucide--mic", "size-3") "Join" }
			@ui.Button(ui.ButtonProps{Size: ui.ButtonXS, Style: ui.ButtonStyleSoft, ExtraClass: "gap-1"}){ @ui.IconSpan("lucide--message-circle", "size-3") "Chat" }
		</div>
	</div>
}

templ SidebarTokenMeter(used int, max int) {
	<div class="mb-3 flex items-center justify-between gap-2">
		<div class="flex items-center gap-1.5">
			<div class={ "radial-progress text-[10px] font-semibold " + sprintRadialClass(used, max) } style={ sprintRadialStyle(used, max) } role="progressbar">
				{ sprintTokenPct(used, max) }
			</div>
			<div>
				<p class="text-xs font-medium">Tokens Used</p>
				<p class="text-base-content/60 text-[10px]">{ sprintTokenFmt(used) }/{ sprintTokenFmt(max) }</p>
			</div>
		</div>
		@ui.Button(ui.ButtonProps{Variant: ui.ButtonGhost, Size: ui.ButtonXS}){ "Upgrade" }
	</div>
}

templ SidebarBottomNav(items []SidebarBottomNavItem) {
	<div class="flex items-center justify-around">
		for _, item := range items {
			if item.Active {
				<a class="flex flex-col items-center gap-0.5 text-primary" href={ templ.SafeURL(item.Href) }>
					<span class={ "iconify size-4 " + item.Icon }></span>
					<span class="text-[10px]">{ item.Label }</span>
				</a>
			} else {
				<a class="flex flex-col items-center gap-0.5 text-base-content/60" href={ templ.SafeURL(item.Href) }>
					<span class={ "iconify size-4 " + item.Icon }></span>
					<span class="text-[10px]">{ item.Label }</span>
				</a>
			}
		}
	</div>
}

templ SidebarVersionSwitcher(versions []string, current string) {
	<div class="dropdown w-full">
		<label tabindex="0" class="btn btn-outline border-base-300 btn-xs w-full justify-between gap-2 font-normal">
			@ui.IconSpan("lucide--git-branch", "size-3 text-base-content/60")
			<span class="grow text-left truncate">{ current }</span>
			@ui.IconSpan("lucide--chevron-down", "size-3 text-base-content/40")
		</label>
		<ul tabindex="0" class="dropdown-content menu menu-xs bg-base-100 rounded-box shadow-lg z-50 w-full p-1 border border-base-content/10 mt-1">
			for _, v := range sprintVersions(current, versions) {
				<li><a class={ templ.KV("active", v == current) }>{ v }</a></li>
			}
		</ul>
	</div>
}

templ SidebarDocCard(icon string, title string, desc string, bgClass string) {
	<div class="rounded-box border border-base-200 p-3">
		<div class="flex items-center gap-3">
			<div class={ "rounded-box flex size-10 items-center justify-center " + bgClass }>
				<span class={ "iconify size-5 " + icon }></span>
			</div>
			<div>
				<p class="text-sm font-medium">{ title }</p>
				<p class="text-base-content/60 text-xs">{ desc }</p>
			</div>
		</div>
	</div>
}

templ SidebarDivider() {
	<div class="border-base-200 mx-2.5 my-4 border-t"></div>
}

templ SidebarToggleRow(label string, toggleClass string) {
	<div class="flex items-center justify-between gap-3 px-2.5 py-2">
		<span class="text-sm">{ label }</span>
		<input type="checkbox" class={ "toggle toggle-sm " + toggleClass } aria-label={ label }/>
	</div>
}
